import os

base_dir = "/mnt/agents/output/saas-backend"

# Read all files and prepare for output
all_files = {}
for root, dirs, files in os.walk(base_dir):
    for file in files:
        if file.endswith('.zip'):  # Skip zip files
            continue
        path = os.path.join(root, file)
        rel_path = os.path.relpath(path, base_dir)
        with open(path, 'r') as f:
            all_files[rel_path] = f.read()

# Print summary
print(f"Total files to paste: {len(all_files)}")
print("Files:", sorted(all_files.keys()))